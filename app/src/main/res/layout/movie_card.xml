<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    style="@style/MyCourseCard"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_margin="@dimen/classic_dimension"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <ImageView
            android:id="@+id/filmsPoster"
            android:layout_width="@dimen/photo_dimension"
            android:layout_height="@dimen/photo_dimension"
            android:layout_marginStart="@dimen/standart_dp"
            android:layout_marginTop="@dimen/standart_dp"
            android:layout_marginBottom="@dimen/standart_dp"
            android:src="@drawable/ic_launcher_background"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/filmsName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/standart_dp"
            android:text="Marvel"
            android:textStyle="bold"
            app:layout_constraintBottom_toTopOf="@id/overview"
            app:layout_constraintStart_toEndOf="@id/filmsPoster"
            app:layout_constraintTop_toTopOf="@id/filmsPoster"
            app:layout_constraintVertical_chainStyle="packed" />

        <TextView
            android:id="@+id/overview"
            android:layout_width="@dimen/zero_dimension"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/standart_dp"
            android:ellipsize="end"
            android:maxLines="2"
            android:text="Фильм о супергероях и прочих говноряхjsansjansja jnajnajkak jakscnajcnjasknckasncjasnjaskcnasjkdnajskdnjasdnkjasdkasdasndkjnasdjasdnasjkdnasjkdnasjkdnasjdnajksdnasjkdnkasdnjkasdaskdnjasdnjkad"
            app:layout_constraintBottom_toBottomOf="@id/filmsPoster"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/filmsPoster"
            app:layout_constraintTop_toBottomOf="@id/filmsName" />

        <TextView
            android:id="@+id/date"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/standart_dp"
            android:text="25 January"
            android:textStyle="italic"
            app:layout_constraintStart_toEndOf="@id/filmsPoster"
            app:layout_constraintTop_toBottomOf="@id/overview" />

        <ImageView
            android:id="@+id/rating"
            android:layout_width="@dimen/rating_dimension"
            android:layout_height="@dimen/rating_dimension"
            android:layout_marginTop="@dimen/standart_dp"
            android:layout_marginEnd="@dimen/standart_dp"
            android:src="@drawable/ic_circle"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/ratingCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/_12dp"
            android:layout_marginEnd="@dimen/_12dp"
            android:text="8.5"
            android:textColor="@color/white"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.cardview.widget.CardView>